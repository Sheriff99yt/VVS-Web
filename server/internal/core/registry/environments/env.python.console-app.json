{
  "id": "env.python.console-app",
  "version": "1.0.0",
  "displayName": "Python Console App",
  "description": "Console application with print native, on_ready lifecycle, and main.py entry runner.",
  "defaultTarget": "python",
  "supportedTargets": ["python", "javascript", "cpp", "verse"],
  "module": {
    "defaultName": "App",
    "extends": { "id": "object" }
  },
  "apiSurface": {
    "types": [
      {
        "id": "object",
        "displayName": "Object",
        "targets": {
          "python": { "extendsName": "object" },
          "javascript": { "extendsName": "Object" },
          "cpp": { "extendsName": "std::enable_shared_from_this" },
          "verse": { "extendsName": "creative_object" }
        }
      }
    ],
    "methods": [
      {
        "id": "native.print",
        "name": "print",
        "parameters": [{ "id": "msg", "label": "Message", "type": "data_string" }],
        "role": "native",
        "targets": {
          "python": { "callExpr": "print({msg})" },
          "javascript": { "callExpr": "console.log({msg})" },
          "cpp": { "callExpr": "std::cout << {msg} << std::endl" },
          "verse": { "callExpr": "Print({msg})" }
        }
      },
      {
        "id": "lifecycle.run",
        "name": "run",
        "parameters": [],
        "role": "overrideable",
        "targets": {
          "python": { "callExpr": "super().run()", "defHeader": "def run(self):" },
          "javascript": { "callExpr": "super.run()", "defHeader": "run() {" },
          "cpp": { "callExpr": "Base::run()", "defHeader": "void run() override {" },
          "verse": { "callExpr": "super.run()", "defHeader": "run():void =" }
        }
      }
    ],
    "events": [
      {
        "id": "event.on_ready",
        "name": "on_ready",
        "parameters": []
      }
    ]
  },
  "hostFiles": [
    {
      "path": "main.py",
      "role": "entry",
      "template": "from {moduleName} import {moduleName}\n\nif __name__ == '__main__':\n    {moduleName}().on_start()\n"
    }
  ]
}
