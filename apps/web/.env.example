# Copy this file to .env.local and adjust for your machine.
# .env.local is gitignored — safe for LAN IPs and local overrides.

# API mode: "mock" (offline localStorage) or "http" (Go backend + local MCP)
# start_app.ps1 sets these automatically; keep them here for manual `bun run dev`:
NEXT_PUBLIC_API_MODE=http
NEXT_PUBLIC_API_URL=http://localhost:8080

# LAN dev: your machine's IPv4 so Next.js allows HMR via http://YOUR_IP:3000
# Run tools/setup_env.ps1 to auto-detect, or set manually:
# DEV_ALLOWED_ORIGIN=192.168.x.x

# Supabase Auth (GoTrue) — optional; enables cloud sign-in UI when both are set:
# Start auth stack: docker compose up -d postgres gotrue auth-gateway
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# NEXT_PUBLIC_GITHUB_OAUTH_ENABLED=true

# Production MCP URL (defaults to NEXT_PUBLIC_API_URL + /mcp)
# NEXT_PUBLIC_MCP_URL=https://api.your-domain/mcp
