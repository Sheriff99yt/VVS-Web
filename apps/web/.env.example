# Copy this file to .env.local and adjust for your machine.
# .env.local is gitignored — safe for LAN IPs and local overrides.

# API mode: "mock" (offline localStorage) or "http" (Go backend + local MCP)
# start_app.ps1 sets these automatically; keep them here for manual `bun run dev`:
NEXT_PUBLIC_API_MODE=http
NEXT_PUBLIC_API_URL=http://localhost:8080

# LAN dev: your machine's IPv4 so Next.js allows HMR via http://YOUR_IP:3000
# Run tools/setup_env.ps1 to auto-detect, or set manually:
# DEV_ALLOWED_ORIGIN=192.168.x.x
