{
  "name": "vvs-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter web dev",
    "build": "bun run --filter web build",
    "test": "bun test packages/syntax-packs packages/transpiler packages/graph-types && bun run --filter web test",
    "env:import": "bun run --filter @vvs/environment-templates import:env"
  }
}
