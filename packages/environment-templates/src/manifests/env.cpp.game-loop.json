{
  "id": "env.cpp.game-loop",
  "version": "1.0.0",
  "displayName": "C++ Game Loop",
  "description": "Tick-based simulation skeleton with tick/delta events — for native and cross-target game logic.",
  "category": "game",
  "defaultTarget": "cpp",
  "supportedTargets": ["cpp", "verse", "python"],
  "module": {
    "defaultName": "GameApp",
    "extends": { "id": "object" }
  },
  "apiSurface": {
    "types": [
      {
        "id": "object",
        "displayName": "Object",
        "targets": {
          "cpp": { "extendsName": "std::enable_shared_from_this<GameApp>" },
          "verse": { "extendsName": "creative_object" },
          "python": { "extendsName": "object" }
        }
      }
    ],
    "methods": [
      {
        "id": "native.print",
        "name": "print",
        "parameters": [{ "id": "msg", "label": "Message", "type": "data_string" }],
        "role": "native",
        "targets": {
          "cpp": { "callExpr": "std::cout << {msg} << std::endl" },
          "verse": { "callExpr": "Print({msg})" },
          "python": { "callExpr": "print({msg})" }
        }
      },
      {
        "id": "lifecycle.run",
        "name": "run",
        "parameters": [],
        "role": "overrideable",
        "targets": {
          "cpp": { "callExpr": "Base::run()", "defHeader": "void run() override {" },
          "verse": { "callExpr": "super.run()", "defHeader": "run():void =" },
          "python": { "callExpr": "super().run()", "defHeader": "def run(self):" }
        }
      },
      {
        "id": "lifecycle.tick",
        "name": "tick",
        "parameters": [{ "id": "delta", "label": "Delta", "type": "data_number" }],
        "role": "overrideable",
        "targets": {
          "cpp": { "callExpr": "Base::tick({delta})", "defHeader": "void tick(float delta) override {" },
          "verse": { "callExpr": "super.tick({delta})", "defHeader": "tick(Delta:float):void =" },
          "python": { "callExpr": "super().tick({delta})", "defHeader": "def tick(self, delta: float):" }
        }
      }
    ],
    "events": [
      { "id": "event.on_ready", "name": "on_ready", "parameters": [] },
      {
        "id": "event.on_tick",
        "name": "on_tick",
        "parameters": [{ "id": "delta", "label": "Delta", "type": "data_number" }]
      }
    ]
  },
  "hostFiles": [
    {
      "path": "main.cpp",
      "role": "entry",
      "template": "#include \"{moduleName}.h\"\n\nint main() {\n    auto game = std::make_shared<{moduleName}>();\n    game->on_start();\n    return 0;\n}\n"
    }
  ]
}
