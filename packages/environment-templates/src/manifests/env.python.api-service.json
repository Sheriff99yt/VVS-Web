{
  "id": "env.python.api-service",
  "version": "1.0.0",
  "displayName": "Python API Service",
  "description": "HTTP service skeleton with request/response hooks — route handlers as overrideable methods.",
  "category": "api",
  "defaultTarget": "python",
  "supportedTargets": ["python", "javascript"],
  "module": {
    "defaultName": "ApiService",
    "extends": { "id": "object" }
  },
  "apiSurface": {
    "types": [
      {
        "id": "object",
        "displayName": "Object",
        "targets": {
          "python": { "extendsName": "object" },
          "javascript": { "extendsName": "Object" }
        }
      }
    ],
    "methods": [
      {
        "id": "native.print",
        "name": "print",
        "parameters": [{ "id": "msg", "label": "Message", "type": "data_string" }],
        "role": "native",
        "targets": {
          "python": { "callExpr": "print({msg})" },
          "javascript": { "callExpr": "console.log({msg})" }
        }
      },
      {
        "id": "native.json_response",
        "name": "json_response",
        "parameters": [{ "id": "body", "label": "Body", "type": "data_string" }],
        "role": "native",
        "targets": {
          "python": { "callExpr": "json.dumps({body})" },
          "javascript": { "callExpr": "JSON.stringify({body})" }
        }
      },
      {
        "id": "lifecycle.run",
        "name": "run",
        "parameters": [],
        "role": "overrideable",
        "targets": {
          "python": { "callExpr": "super().run()", "defHeader": "def run(self):" },
          "javascript": { "callExpr": "super.run()", "defHeader": "run() {" }
        }
      },
      {
        "id": "handler.health",
        "name": "health",
        "parameters": [],
        "role": "overrideable",
        "targets": {
          "python": { "callExpr": "return {'status': 'ok'}", "defHeader": "def health(self):" },
          "javascript": { "callExpr": "return { status: 'ok' }", "defHeader": "health() {" }
        }
      }
    ],
    "events": [
      { "id": "event.on_ready", "name": "on_ready", "parameters": [] },
      {
        "id": "event.on_request",
        "name": "on_request",
        "parameters": [
          { "id": "method", "label": "Method", "type": "data_string" },
          { "id": "path", "label": "Path", "type": "data_string" }
        ]
      }
    ]
  },
  "hostFiles": [
    {
      "path": "main.py",
      "role": "entry",
      "template": "from {moduleName} import {moduleName}\n\nif __name__ == '__main__':\n    service = {moduleName}()\n    service.on_start()\n"
    },
    {
      "path": "routes.json",
      "role": "config",
      "template": "{\n  \"routes\": [\n    { \"method\": \"GET\", \"path\": \"/health\", \"handler\": \"health\" }\n  ]\n}\n"
    }
  ]
}
