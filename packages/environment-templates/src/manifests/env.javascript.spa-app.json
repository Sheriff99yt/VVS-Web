{
  "id": "env.javascript.spa-app",
  "version": "1.0.0",
  "displayName": "JavaScript SPA",
  "description": "Single-page app with DOM mount point, styles asset, and modular entry.",
  "category": "web",
  "defaultTarget": "javascript",
  "supportedTargets": ["javascript", "python"],
  "module": {
    "defaultName": "App",
    "extends": { "id": "object" }
  },
  "apiSurface": {
    "types": [
      {
        "id": "object",
        "displayName": "Object",
        "targets": {
          "javascript": { "extendsName": "Object" },
          "python": { "extendsName": "object" }
        }
      }
    ],
    "methods": [
      {
        "id": "native.log",
        "name": "log",
        "parameters": [{ "id": "msg", "label": "Message", "type": "data_string" }],
        "role": "native",
        "targets": {
          "javascript": { "callExpr": "console.log({msg})" },
          "python": { "callExpr": "print({msg})" }
        }
      },
      {
        "id": "native.mount",
        "name": "mount",
        "parameters": [{ "id": "selector", "label": "Selector", "type": "data_string" }],
        "role": "native",
        "targets": {
          "javascript": { "callExpr": "document.querySelector({selector})" }
        }
      },
      {
        "id": "lifecycle.run",
        "name": "run",
        "parameters": [],
        "role": "overrideable",
        "targets": {
          "javascript": { "callExpr": "super.run()", "defHeader": "run() {" },
          "python": { "callExpr": "super().run()", "defHeader": "def run(self):" }
        }
      }
    ],
    "events": [
      { "id": "event.on_ready", "name": "on_ready", "parameters": [] },
      {
        "id": "event.on_route",
        "name": "on_route",
        "parameters": [{ "id": "path", "label": "Path", "type": "data_string" }]
      }
    ]
  },
  "hostFiles": [
    {
      "path": "index.html",
      "role": "entry",
      "template": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>{moduleName}</title>\n  <link rel=\"stylesheet\" href=\"styles.css\" />\n</head>\n<body>\n  <div id=\"root\"></div>\n  <script type=\"module\" src=\"main.js\"></script>\n</body>\n</html>\n"
    },
    {
      "path": "main.js",
      "role": "entry",
      "template": "import { {moduleName} } from './{moduleName}.js';\n\nconst app = new {moduleName}();\napp.on_start();\n"
    },
    {
      "path": "styles.css",
      "role": "asset",
      "template": "body { font-family: system-ui, sans-serif; margin: 0; }\n#root { padding: 1rem; }\n"
    }
  ]
}
