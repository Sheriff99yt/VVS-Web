{
  "id": "env.cpp.console-app",
  "version": "1.0.0",
  "displayName": "C++ Console App",
  "description": "Native console application with iostream print native and main.cpp entry.",
  "category": "console",
  "defaultTarget": "cpp",
  "supportedTargets": ["cpp", "python"],
  "module": {
    "defaultName": "App",
    "extends": { "id": "object" }
  },
  "apiSurface": {
    "types": [
      {
        "id": "object",
        "displayName": "Object",
        "targets": {
          "cpp": { "extendsName": "std::enable_shared_from_this<App>" },
          "python": { "extendsName": "object" }
        }
      }
    ],
    "methods": [
      {
        "id": "native.print",
        "name": "print",
        "parameters": [{ "id": "msg", "label": "Message", "type": "data_string" }],
        "role": "native",
        "targets": {
          "cpp": { "callExpr": "std::cout << {msg} << std::endl" },
          "python": { "callExpr": "print({msg})" }
        }
      },
      {
        "id": "lifecycle.run",
        "name": "run",
        "parameters": [],
        "role": "overrideable",
        "targets": {
          "cpp": { "callExpr": "Base::run()", "defHeader": "void run() override {" },
          "python": { "callExpr": "super().run()", "defHeader": "def run(self):" }
        }
      }
    ],
    "events": [
      { "id": "event.on_ready", "name": "on_ready", "parameters": [] }
    ]
  },
  "hostFiles": [
    {
      "path": "main.cpp",
      "role": "entry",
      "template": "#include \"{moduleName}.h\"\n#include <iostream>\n\nint main() {\n    auto app = std::make_shared<{moduleName}>();\n    app->on_start();\n    return 0;\n}\n"
    }
  ]
}
