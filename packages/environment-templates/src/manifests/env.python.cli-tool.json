{
  "id": "env.python.cli-tool",
  "version": "1.0.0",
  "displayName": "Python CLI Tool",
  "description": "Argument-driven CLI with print and input natives — ideal for scripts and automation.",
  "category": "console",
  "defaultTarget": "python",
  "supportedTargets": ["python", "javascript"],
  "module": {
    "defaultName": "CliApp",
    "extends": { "id": "object" }
  },
  "apiSurface": {
    "types": [
      {
        "id": "object",
        "displayName": "Object",
        "targets": {
          "python": { "extendsName": "object" },
          "javascript": { "extendsName": "Object" }
        }
      }
    ],
    "methods": [
      {
        "id": "native.print",
        "name": "print",
        "parameters": [{ "id": "msg", "label": "Message", "type": "data_string" }],
        "role": "native",
        "targets": {
          "python": { "callExpr": "print({msg})" },
          "javascript": { "callExpr": "console.log({msg})" }
        }
      },
      {
        "id": "native.parse_args",
        "name": "parse_args",
        "parameters": [],
        "role": "native",
        "targets": {
          "python": { "callExpr": "argparse.ArgumentParser().parse_args()" },
          "javascript": { "callExpr": "process.argv.slice(2)" }
        }
      },
      {
        "id": "lifecycle.run",
        "name": "run",
        "parameters": [],
        "role": "overrideable",
        "targets": {
          "python": { "callExpr": "super().run()", "defHeader": "def run(self):" },
          "javascript": { "callExpr": "super.run()", "defHeader": "run() {" }
        }
      }
    ],
    "events": [
      { "id": "event.on_ready", "name": "on_ready", "parameters": [] },
      {
        "id": "event.on_arg",
        "name": "on_arg",
        "parameters": [{ "id": "name", "label": "Name", "type": "data_string" }]
      }
    ]
  },
  "hostFiles": [
    {
      "path": "main.py",
      "role": "entry",
      "template": "import argparse\nfrom {moduleName} import {moduleName}\n\nif __name__ == '__main__':\n    parser = argparse.ArgumentParser(prog='{moduleName}')\n    args = parser.parse_args()\n    {moduleName}().on_start()\n"
    }
  ]
}
