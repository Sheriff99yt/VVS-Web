{
  "id": "env.gdscript.godot-game",
  "version": "1.0.0",
  "displayName": "Godot Game (GDScript)",
  "description": "Node-based game skeleton with _ready and _process hooks — for Godot 4 GDScript projects.",
  "category": "game",
  "defaultTarget": "gdscript",
  "supportedTargets": ["gdscript", "python"],
  "module": {
    "defaultName": "GameApp",
    "extends": { "id": "node" }
  },
  "apiSurface": {
    "types": [
      {
        "id": "node",
        "displayName": "Node",
        "targets": {
          "gdscript": { "extendsName": "Node" },
          "python": { "extendsName": "object" }
        }
      }
    ],
    "methods": [
      {
        "id": "native.print",
        "name": "print",
        "parameters": [{ "id": "msg", "label": "Message", "type": "data_string" }],
        "role": "native",
        "targets": {
          "gdscript": { "callExpr": "print({msg})" },
          "python": { "callExpr": "print({msg})" }
        }
      },
      {
        "id": "lifecycle.ready",
        "name": "_ready",
        "parameters": [],
        "role": "overrideable",
        "targets": {
          "gdscript": { "callExpr": "super._ready()", "defHeader": "func _ready() -> void:" },
          "python": { "callExpr": "super().run()", "defHeader": "def run(self):" }
        }
      },
      {
        "id": "lifecycle.process",
        "name": "_process",
        "parameters": [{ "id": "delta", "label": "Delta", "type": "data_number" }],
        "role": "overrideable",
        "targets": {
          "gdscript": {
            "callExpr": "super._process({delta})",
            "defHeader": "func _process(delta: float) -> void:"
          },
          "python": { "callExpr": "super().tick({delta})", "defHeader": "def tick(self, delta: float):" }
        }
      }
    ],
    "events": [
      { "id": "event.on_ready", "name": "on_ready", "parameters": [] },
      {
        "id": "event.on_tick",
        "name": "on_tick",
        "parameters": [{ "id": "delta", "label": "Delta", "type": "data_number" }]
      }
    ]
  },
  "hostFiles": [
    {
      "path": "project.godot",
      "role": "config",
      "template": "; Godot 4 project stub — attach {moduleName}.gd to your main scene root.\nconfig_version=5\n\n[application]\nrun/main_scene=\"res://main.tscn\"\n"
    }
  ]
}
