{
  "id": "env.javascript.node-script",
  "version": "1.0.0",
  "displayName": "Node.js Script",
  "description": "Node CLI script with console logging and process argv — for tooling and automation.",
  "category": "console",
  "defaultTarget": "javascript",
  "supportedTargets": ["javascript", "python"],
  "module": {
    "defaultName": "Script",
    "extends": { "id": "object" }
  },
  "apiSurface": {
    "types": [
      {
        "id": "object",
        "displayName": "Object",
        "targets": {
          "javascript": { "extendsName": "Object" },
          "python": { "extendsName": "object" }
        }
      }
    ],
    "methods": [
      {
        "id": "native.log",
        "name": "log",
        "parameters": [{ "id": "msg", "label": "Message", "type": "data_string" }],
        "role": "native",
        "targets": {
          "javascript": { "callExpr": "console.log({msg})" },
          "python": { "callExpr": "print({msg})" }
        }
      },
      {
        "id": "native.exit",
        "name": "exit",
        "parameters": [{ "id": "code", "label": "Code", "type": "data_number" }],
        "role": "native",
        "targets": {
          "javascript": { "callExpr": "process.exit({code})" }
        }
      },
      {
        "id": "lifecycle.run",
        "name": "run",
        "parameters": [],
        "role": "overrideable",
        "targets": {
          "javascript": { "callExpr": "super.run()", "defHeader": "run() {" },
          "python": { "callExpr": "super().run()", "defHeader": "def run(self):" }
        }
      }
    ],
    "events": [
      { "id": "event.on_ready", "name": "on_ready", "parameters": [] }
    ]
  },
  "hostFiles": [
    {
      "path": "main.js",
      "role": "entry",
      "template": "import { {moduleName} } from './{moduleName}.js';\n\nconst app = new {moduleName}();\napp.on_start();\n"
    },
    {
      "path": "package.json",
      "role": "config",
      "template": "{\n  \"name\": \"{moduleName}\",\n  \"type\": \"module\",\n  \"main\": \"main.js\"\n}\n"
    }
  ]
}
