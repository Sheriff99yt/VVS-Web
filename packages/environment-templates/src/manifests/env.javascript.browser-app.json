{
  "id": "env.javascript.browser-app",
  "version": "1.0.0",
  "displayName": "JavaScript Browser App",
  "description": "Browser application with DOM console native, on_ready lifecycle, and index.html entry.",
  "category": "web",
  "defaultTarget": "javascript",
  "supportedTargets": ["javascript", "python"],
  "module": {
    "defaultName": "App",
    "extends": { "id": "object" }
  },
  "apiSurface": {
    "types": [
      {
        "id": "object",
        "displayName": "Object",
        "targets": {
          "javascript": { "extendsName": "Object" },
          "python": { "extendsName": "object" }
        }
      }
    ],
    "methods": [
      {
        "id": "native.log",
        "name": "log",
        "parameters": [{ "id": "msg", "label": "Message", "type": "data_string" }],
        "role": "native",
        "targets": {
          "javascript": { "callExpr": "console.log({msg})" },
          "python": { "callExpr": "print({msg})" }
        }
      },
      {
        "id": "native.alert",
        "name": "alert",
        "parameters": [{ "id": "msg", "label": "Message", "type": "data_string" }],
        "role": "native",
        "targets": {
          "javascript": { "callExpr": "alert({msg})" }
        }
      },
      {
        "id": "lifecycle.run",
        "name": "run",
        "parameters": [],
        "role": "overrideable",
        "targets": {
          "javascript": { "callExpr": "super.run()", "defHeader": "run() {" },
          "python": { "callExpr": "super().run()", "defHeader": "def run(self):" }
        }
      }
    ],
    "events": [
      {
        "id": "event.on_ready",
        "name": "on_ready",
        "parameters": []
      },
      {
        "id": "event.on_click",
        "name": "on_click",
        "parameters": [{ "id": "target", "label": "Target", "type": "data_string" }]
      }
    ]
  },
  "hostFiles": [
    {
      "path": "index.html",
      "role": "entry",
      "template": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <title>{moduleName}</title>\n  <script type=\"module\" src=\"./main.js\"></script>\n</head>\n<body>\n  <div id=\"app\"></div>\n</body>\n</html>\n"
    },
    {
      "path": "main.js",
      "role": "entry",
      "template": "import { {moduleName} } from './{moduleName}.js';\n\nconst app = new {moduleName}();\napp.on_start();\n"
    }
  ]
}
