{
  "id": "env.python.data-script",
  "version": "1.0.0",
  "displayName": "Python Data Script",
  "description": "File-driven data pipeline with read and process hooks — CSV/JSON friendly.",
  "category": "data",
  "defaultTarget": "python",
  "supportedTargets": ["python", "javascript"],
  "module": {
    "defaultName": "DataPipeline",
    "extends": { "id": "object" }
  },
  "apiSurface": {
    "types": [
      {
        "id": "object",
        "displayName": "Object",
        "targets": {
          "python": { "extendsName": "object" },
          "javascript": { "extendsName": "Object" }
        }
      }
    ],
    "methods": [
      {
        "id": "native.print",
        "name": "print",
        "parameters": [{ "id": "msg", "label": "Message", "type": "data_string" }],
        "role": "native",
        "targets": {
          "python": { "callExpr": "print({msg})" },
          "javascript": { "callExpr": "console.log({msg})" }
        }
      },
      {
        "id": "native.read_file",
        "name": "read_file",
        "parameters": [{ "id": "path", "label": "Path", "type": "data_string" }],
        "role": "native",
        "targets": {
          "python": { "callExpr": "open({path}, encoding='utf-8').read()" },
          "javascript": { "callExpr": "await fs.readFile({path}, 'utf8')" }
        }
      },
      {
        "id": "lifecycle.run",
        "name": "run",
        "parameters": [],
        "role": "overrideable",
        "targets": {
          "python": { "callExpr": "super().run()", "defHeader": "def run(self):" },
          "javascript": { "callExpr": "super.run()", "defHeader": "run() {" }
        }
      }
    ],
    "events": [
      { "id": "event.on_ready", "name": "on_ready", "parameters": [] },
      {
        "id": "event.on_row",
        "name": "on_row",
        "parameters": [{ "id": "row", "label": "Row", "type": "data_string" }]
      }
    ]
  },
  "hostFiles": [
    {
      "path": "main.py",
      "role": "entry",
      "template": "from {moduleName} import {moduleName}\n\nif __name__ == '__main__':\n    pipeline = {moduleName}()\n    pipeline.on_start()\n"
    },
    {
      "path": "data/sample.csv",
      "role": "asset",
      "template": "id,name\n1,example\n"
    }
  ]
}
